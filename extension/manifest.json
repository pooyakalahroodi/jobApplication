{
  "manifest_version": 3,
  "name": "Job Application Capture",
  "version": "0.1.0",
  "description": "Capture job advertisements into the local job applications dashboard.",
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Save Job"
  },
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://127.0.0.1:8000/*", "http://localhost:8000/*"]
}

